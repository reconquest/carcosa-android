<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="IconButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">#E6F1F5</item>
        <item name="rippleColor">#00E5FF</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="iconPadding">0dp</item>
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginLeft">4dp</item>
    </style>
    <style name="IconButton.Black" parent="IconButton">
        <item name="iconTint">#030406</item>
    </style>
    <style name="Green">
        <item name="android:textColor">#B6FF00</item>
    </style>
    <style name="Gray">
        <item name="android:textColor">#6E7D86</item>
    </style>
    <style name="SSH">
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="SSH.Fingerprint" parent="SSH">
        <item name="android:textColor">#B6FF00</item>
    </style>
    <style name="SSH.Fingerprint.Ellipsis">
        <item name="android:textColor">#6E7D86</item>
        <item name="android:paddingLeft">4dp</item>
        <item name="android:paddingRight">4dp</item>
    </style>
    <style name="Icon">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:adjustViewBounds">true</item>
    </style>
    <style name="Icon.Green" parent="Icon">
        <item name="android:tint">#B6FF00</item>
    </style>
    <style name="Divider">
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_marginLeft">8dp</item>
        <item name="android:layout_marginRight">8dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:background">#27323A</item>
    </style>
    <style name="HelperText"
        parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">#6E7D86</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="Readonly"
        parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">#6E7D86</item>
        <item name="android:fontFamily">monospace</item>
    </style>
    <style name="CyberPanelText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">#E6F1F5</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>
