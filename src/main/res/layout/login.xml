<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#030406"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp"
        android:background="@drawable/cyber_panel_hot"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="22dp"
        android:paddingTop="28dp"
        android:paddingRight="22dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:text="CARCOSA"
            android:textColor="#FFB000"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:text="// VAULT AUTH GATE"
            android:textColor="#00E5FF"
            android:textSize="12sp" />

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="Vault authentication"
            android:src="@drawable/ic_fingerprint_24dp"
            android:tint="#B6FF00" />

        <LinearLayout
            android:id="@+id/pin_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/pin_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="center"
                android:textColor="#9BB6C7"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/pin_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:digits="0123456789"
                android:fontFamily="monospace"
                android:hint="PIN"
                android:inputType="numberPassword"
                android:singleLine="true"
                android:textColor="#D6E8F0"
                android:textColorHint="#6E7D86" />

            <EditText
                android:id="@+id/pin_confirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:digits="0123456789"
                android:fontFamily="monospace"
                android:hint="Confirm PIN"
                android:inputType="numberPassword"
                android:singleLine="true"
                android:textColor="#D6E8F0"
                android:textColorHint="#6E7D86" />

            <TextView
                android:id="@+id/pin_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:textColor="#FF4D6D"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <Button
            android:id="@+id/login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="monospace"
            android:text="AUTHENTICATE" />

        <ProgressBar
            android:id="@+id/login_progress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:indeterminateTint="#FFB000"
            android:visibility="gone" />

        <TextView
            android:id="@+id/login_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="encrypted pin cache requires live biometric session"
            android:textColor="#6E7D86"
            android:textSize="11sp" />

    </LinearLayout>
</RelativeLayout>
